---
import Head from '../components/Head.astro'
import { seo } from '../settings'

type Props = {
	title?: string
	description?: string
	image?: string
}

const {
	title = seo.default_title,
	description = seo.default_description,
	image = seo.default_image,
} = Astro.props
---

<!doctype html>
<html lang='en'>
	<head>
		<Head title={title} description={description} image={image} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	html, body {
		margin: 0;
		padding: 0;
		background: #ffffff;
		color: #000000;
	}

	body, td, th, tr, p, a {
		font-family: 'Lato', Verdana, Helvetica, sans-serif;
		font-size: 14px;
		line-height: 1.45;
	}

	strong {
		font-family: 'Lato', Verdana, Helvetica, sans-serif;
		font-size: 14px;
	}

	a {
		color: #1772d0;
		text-decoration: none;
	}

	a:focus, a:hover {
		color: #f09228;
		text-decoration: none;
	}

	h2 {
		margin: 0 0 8px 0;
		padding-bottom: 0;
		border-bottom: 0;
		font-weight: normal;
		font-family: 'Lato', Verdana, Helvetica, sans-serif;
		font-size: 22px;
	}

	.papertitle {
		font-family: 'Lato', Verdana, Helvetica, sans-serif;
		font-size: 14px;
		font-weight: 700;
	}

	.name {
		padding-top: 0;
		margin: 0 0 10px 0;
		font-family: 'Lato', Verdana, Helvetica, sans-serif;
		font-size: 32px;
		font-weight: 700;
		letter-spacing: 0;
		text-align: center;
	}

	.bio {
		margin: 0 0 14px 0;
		text-align: left;
	}

	span.highlight {
		background-color: #ffffd0;
	}

	.outer {
		width: 100%;
		max-width: 880px;
		margin: 0 auto;
		border: 0;
		border-spacing: 0;
		border-collapse: separate;
		padding: 0 16px;
	}

	.outer td {
		padding: 0;
	}

	.header-table {
		width: 100%;
		border: 0;
		border-spacing: 0;
		border-collapse: separate;
		margin-top: 24px;
	}

	.header-text-cell {
		padding: 0 24px 0 8px;
		width: 64%;
		vertical-align: middle;
	}

	.header-photo-cell {
		padding: 0 8px;
		width: 36%;
		max-width: 36%;
		vertical-align: middle;
		text-align: right;
	}

	.profile-photo {
		width: 100%;
		max-width: 280px;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 4px;
		display: inline-block;
		box-shadow: none;
	}

	.section-table {
		width: 100%;
		border: 0;
		border-spacing: 0;
		border-collapse: separate;
		margin-top: 28px;
	}

	.section-cell {
		padding: 8px 8px 0 8px;
		width: 100%;
		vertical-align: middle;
	}

	.pubs-table {
		width: 100%;
		border: 0;
		border-spacing: 0 12px;
		border-collapse: separate;
	}

	.thumb-cell {
		padding: 12px 8px;
		width: 180px;
		vertical-align: middle;
	}

	.entry-cell {
		padding: 12px 8px 12px 4px;
		vertical-align: middle;
	}

	.thumb {
		width: 160px;
		height: 160px;
		object-fit: cover;
		display: block;
		border-radius: 4px;
	}

	.contact-line {
		text-align: center;
		margin: 0;
	}

	.contact-line .sep {
		color: #999;
		margin: 0 4px;
	}

	.muted {
		color: #777;
		font-style: italic;
		margin: 8px 0 0 0;
	}

	.post-meta {
		color: #555;
		font-size: 13px;
	}

	.post-tags {
		color: #777;
		font-size: 13px;
	}

	.post-tags .tag {
		color: #777;
	}

	.excerpt {
		margin: 8px 0 6px 0;
		color: #333;
	}

	.footer-credit {
		text-align: right;
		font-size: 12px;
		color: #777;
		padding: 32px 8px 24px 8px;
	}

	@media (max-width: 700px) {
		.header-table tbody tr {
			display: flex;
			flex-direction: column-reverse;
		}
		.header-text-cell, .header-photo-cell {
			display: block;
			width: 100%;
			max-width: 100%;
			padding: 8px;
			text-align: center;
		}
		.profile-photo {
			max-width: 220px;
		}
		.name {
			font-size: 28px;
			padding-top: 8px;
		}
		.contact-line {
			text-align: center;
		}
		.thumb-cell {
			width: 120px;
		}
		.thumb {
			width: 110px;
			height: 110px;
		}
	}
</style>
